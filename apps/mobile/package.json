{
  "name": "mobile",
  "version": "1.0.0",
  "description": "Live countdown for Fortnite.",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "tsc --noEmit",
    "lint": "echo \"expo lint optional\"",
    "dev": "expo start",
    "test": "node -e \"process.exit(0)\"",
    "bundle:android": "node ./scripts/bundle-android.cjs",
    "android:release:aab": "npm run bundle:android && node ./scripts/gradle-bundle-release.cjs"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.0.0",
    "@fortnite-live-countdown/types": "file:../../packages/types",
    "@fortnite-live-countdown/ui": "file:../../packages/ui",
    "@fortnite-live-countdown/utils": "file:../../packages/utils",
    "@tanstack/react-query": "^5.66.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.0",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.2.4",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@react-native/metro-config": "^0.84.1",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.3",
    "typescript": "~5.9.2"
  }
}
